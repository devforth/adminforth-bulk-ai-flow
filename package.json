{
  "name": "@adminforth/bulk-ai-flow",
  "version": "1.0.1",
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "homepage": "https://adminforth.dev/docs/tutorial/Plugins/bulk-ai-flow/",
  "scripts": {
    "build": "tsc && rsync -av --exclude 'node_modules' custom dist/"
  },
  "keywords": [
    "adminforth",
    "ai-workflows",
    "batch-generation",
    "record-enrichment",
    "prompt-templates",
    "image-processing",
    "field-generation"
  ],
  "author": "DevForth (https://devforth.io)",
  "license": "MIT",
  "description": "Bulk AI workflow plugin for AdminForth for batch field generation and image processing",
  "devDependencies": {
    "@types/node": "latest",
    "adminforth": "^2.42.0",
    "semantic-release": "^24.2.1",
    "semantic-release-slack-bot": "^4.0.2",
    "typescript": "^5.7.3"
  },
  "dependencies": {
    "@types/handlebars": "^4.0.40",
    "handlebars": "^4.7.8"
  },
  "peerDependencies": {
    "adminforth": "^2.42.0"
  },
  "release": {
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      "@semantic-release/npm",
      "@semantic-release/github",
      [
        "semantic-release-slack-bot",
        {
          "packageName": "@adminforth/bulk-ai-flow",
          "notifyOnSuccess": true,
          "notifyOnFail": true,
          "slackIcon": ":package:",
          "markdownReleaseNotes": true
        }
      ]
    ],
    "branches": [
      "main",
      {
        "name": "next",
        "prerelease": true
      }
    ]
  }
}
